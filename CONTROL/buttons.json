{
  "regular": [
    {
      "group": "מחשב סלון",
      "label": "פתח Chrome",
      "target": "pc",
      "action": "start chrome"
    },
    {
      "group": "מחשב סלון",
      "label": "פתח Zoom",
      "target": "pc",
      "action": "start zoom"
    },
    {
      "group": "מחשב סלון",
      "label": "פתח מסמכים",
      "target": "pc",
      "action": "start explorer %USERPROFILE%\\\\Documents"
    },
    {
      "group": "מחשב סלון",
      "label": "פתח שולחן עבודה",
      "target": "pc",
      "action": "start explorer %USERPROFILE%\\\\Desktop"
    }
  ],
  "sensitive": [
    {
      "group": "מערכת",
      "label": "רענון רשת",
      "target": "pc",
      "action": "ipconfig /release && ipconfig /renew"
    }
  ],
  "dangerous": [
    {
      "group": "מחשב סלון",
      "label": "כבה מחשב",
      "target": "pc",
      "action": "shutdown /s /t 0"
    }
  ]
}