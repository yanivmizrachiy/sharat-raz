{
  "מחשב סלון": [
    {
      "label": "בדוק מצב מחשב",
      "target": "pc",
      "action": "hostname"
    },
    {
      "label": "מי מחובר",
      "target": "pc",
      "action": "whoami"
    },
    {
      "label": "מידע מערכת",
      "target": "pc",
      "action": "systeminfo"
    },
    {
      "label": "בדוק רשת",
      "target": "pc",
      "action": "ipconfig"
    },
    {
      "label": "רשימת קבצים",
      "target": "pc",
      "action": "dir"
    }
  ],
  "מצלמה": [
    {
      "label": "בדוק מצלמה",
      "target": "pc",
      "action": "wmic path Win32_PnPEntity get Name,Status"
    },
    {
      "label": "חפש מצלמה",
      "target": "pc",
      "action": "wmic path Win32_PnPEntity get Name | findstr /i camera"
    }
  ],
  "מערכת": [
    {
      "label": "רענון מצב",
      "target": "pc",
      "action": "hostname"
    }
  ],
  "מערכת מתקדמת": [
    {
      "label": "תהליכים פעילים",
      "target": "pc",
      "action": "tasklist"
    },
    {
      "label": "בדוק Tailscale",
      "target": "pc",
      "action": "ipconfig"
    },
    {
      "label": "בדוק שירותים",
      "target": "pc",
      "action": "sc query type= service state= all"
    },
    {
      "label": "סטטוס משתמש",
      "target": "pc",
      "action": "query user"
    }
  ],
  "מסך": [
    {
      "label": "בדוק מסך",
      "target": "pc",
      "action": "powershell -NoProfile -Command \"Get-CimInstance Win32_DesktopMonitor | Select-Object Name,Status,MonitorType | ConvertTo-Json -Compress\""
    }
  ]
}